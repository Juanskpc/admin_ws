# ===============================================
# ESCALAPP - Backend Environment Variables
# ===============================================
# Copy this file to .env and adjust values for your environment

# ======== SERVIDOR ========
PORT=3000
NODE_ENV=development

# ======== BASE DE DATOS (Railway PostgreSQL) ========
DB_HOST=caboose.proxy.rlwy.net
DB_PORT=59421
DB_NAME=railway
DB_USER=postgres
DB_PASS=your_db_password_here
DB_SSL=true

# ======== JWT ========
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# ======== CORS CONFIGURATION ========
# DEVELOPMENT: Múltiples orígenes locales
# CORS_ORIGIN=http://localhost:4002,http://localhost:4003,http://localhost:6002
#
# PRODUCTION: Solo el dominio principal (todas las apps están bajo escalapp.cloud)
CORS_ORIGIN=https://escalapp.cloud

# ======== FRONTEND URLs (para redirecciones en correos, etc.) ========
# DEVELOPMENT
# FRONTEND_URL=http://localhost:4002
#
# PRODUCTION
FRONTEND_URL=https://escalapp.cloud

# ======== CORREO ELECTRÓNICO (SMTP) ========
# En desarrollo, si no se configuran MAIL_USER/MAIL_PASS,
# el OTP se imprime en consola sin enviar correo real.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=escalappsystem@gmail.com
MAIL_PASS=your_app_password_here

# ======== NOTAS DE CONFIGURACIÓN ========
# [PRODUCTION DEPLOYMENT]
# 1. NODE_ENV debe ser 'production'
# 2. CORS_ORIGIN debe ser 'https://escalapp.cloud'
# 3. FRONTEND_URL debe ser 'https://escalapp.cloud'
# 4. JWT_SECRET debe ser una clave fuerte y segura
# 5. DB_PASS debe ser la contraseña real de producción
# 6. Usar variables de entorno del servidor EC2 en lugar de hardcoding
